# Your Bad Theory Labs runtime key
GATEWAY_API_KEY=btl-xxxxxxxxxxxxxxxx

# Runtime base URL (OpenAI-compatible)
BTL_BASE_URL=https://api.badtheorylabs.com/v1

# Model used as the "premium baseline" we measure savings against.
# Must be an OpenAI-surface route (not an Anthropic-direct model).
BASELINE_MODEL=gpt-4o

# Client API keys callers must present (comma-separated). Leave empty to keep
# the proxy open. When set, /v1/chat/completions and the control endpoints
# require 'Authorization: Bearer <key>'.
# ARBITER_API_KEYS=arb_xxx,arb_yyy
